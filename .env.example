# Copie para .env (desenvolvimento local) ou configure no painel do Render
SECRET_KEY=troque-por-uma-chave-aleatoria
DATABASE_URL=sqlite:///validade.db
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
ADMIN_SENHA=defina-uma-senha-forte
CRON_TOKEN=token-aleatorio-para-o-cron

# E-mail (opcional — sem SMTP_HOST os alertas por e-mail ficam desativados)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seuemail@gmail.com
SMTP_PASS=senha-de-app
EMAIL_FROM=seuemail@gmail.com
